<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="main-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.GameController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER" spacing="50.0" styleClass="status-bar">
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Player HP" styleClass="hp-label"/>
            <ProgressBar fx:id="playerHpBar" progress="1.0" styleClass="player-hp" prefWidth="200.0" />
        </VBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Boss HP" styleClass="hp-label"/>
            <ProgressBar fx:id="bossHpBar" progress="1.0" styleClass="boss-hp" prefWidth="200.0" />
        </VBox>
    </HBox>

    <ImageView fx:id="bossImage" fitHeight="250.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" />

    <Label fx:id="questionLabel" text="Loading Question..." wrapText="true" textAlignment="CENTER" styleClass="question-label" prefHeight="100.0" prefWidth="600.0" />

    <VBox fx:id="optionsContainer" spacing="15.0" alignment="CENTER" prefWidth="600.0">
        <!-- Buttons will be dynamically added here -->
    </VBox>

    <Label fx:id="feedbackLabel" text="" styleClass="feedback-label" />
</VBox>
